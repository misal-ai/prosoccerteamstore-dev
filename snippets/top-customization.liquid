<div>
  <input
    type="checkbox"
    {% if existing_item_min_quantity == blank or existing_item_min_quantity < 7 %}
      disabled
    {% endif %}
    {% if existing_item_min_quantity > 6 %}
      class="already"
    {% endif %}
    id="show_custom_info"
    name="properties[show_custom_info]"
  >
  <label>Customize this product (Customize and Discounts apply to order quantities of 7+)</label>

  <div class="custom_info" style="display: none; margin-bottom: 10px;">
    <div class='vectorization_info_holder'>
      <p><strong>NOTE: </strong>A $25.00 logo processing fee will be applied to cart. Team logos will be on the opposite side of the brand logo.</p>
    </div>

    <div id="front_section" class="my-1">
      <h3>Front Customizations</h3>
      
      <div class="crest_logo_holder">
         <div class="mt-1">
            <h6 class="product-inner-heading">Crest Logo Type</h6>
            <div class="multi-toggle-group mt-2">
              <input checked class='imageCheckbox' type="radio" name="properties[TopCrestLogoType]" id="top_no_crest_logo" value='0' data-name="no">
              <label for='top_no_crest_logo'>No Logo</label><br>
              <input class='imageCheckbox' type="radio" name="properties[TopCrestLogoType]" value="50434669150510" id="top_crest_heat_press" data-name='Heat Press'>
              <label for="top_crest_heat_press">Heat Press ($7)</label><br>
              <input class='imageCheckbox' type="radio" name="properties[TopCrestLogoType]" value="50434672394542" id="top_crest_embroidery_press" data-name='Embroidery'>
              <label for="top_crest_embroidery_press">Embroidery ($12)</label><br>
            </div>
            <div class="top_crest_logo_image_holder logo_holder row" style="display: none; margin-top:10px;margin-left:2px;">
                <div class='col-12'>Custom Crest Logo</div>
                <div class='col'>
                  <input accept=".png,.svg,.pdf,.ai,.eps,.jpg,.jpeg,.psd,.tif,.tiff" onchange='validateFile(this);' id="crest_logo" name="properties[Crest_Logo]" type="file">
                </div>
                <div class="col">
                  <img width="" height="" alt="crest-logo" src="{{ 'crest_logo.png' | asset_url }}">
                </div>
            </div>
         </div>
      </div>

      <div class="chest_logo_holder mt-3">
        <h6 class="product-inner-heading">Chest Logo Type</h6>
        <div class="multi-toggle-group mt-2">
          <input checked class='imageCheckbox' type="radio" name="properties[TopChestLogoType]" id="top_no_chest_logo" value='0' data-name='no'>
          <label for='top_no_chest_logo'>No Logo</label><br>
          <input class='imageCheckbox' type="radio" name="properties[TopChestLogoType]" value="50434671542574" id="top_chest_heat_press" data-name='Heat Press'>
          <label for="top_chest_heat_press">Heat Press ($10)</label><br>
          <input class='imageCheckbox' type="radio" name="properties[TopChestLogoType]" value="50434669576494" id="top_chest_embroidery_press" data-name='Embroidery'>
          <label for="top_chest_embroidery_press">Embroidery ($15)</label><br>
        </div>
        <div class="top_chest_logo_image_holder logo_holder row" style="display: none; margin-top:10px;">
           <div class="heading col-12">Custom Chest Logo</div>
            <div class='col'>
              <input accept=".png,.svg,.pdf,.ai,.eps,.jpg,.jpeg,.psd,.tif,.tiff" onchange='validateFile(this);' id="chest_logo" name="properties[Chest_Logo]" type="file">
            </div>
            <div class="col">
              <img width="100" height="100" alt="chest-logo" src="{{ 'chest-logo.jpg' | asset_url }}">
            </div>
        </div>
      </div>

      <div class="mt-3">
        <h6 class="product-inner-heading">2" Small Number:</h6>
         <div class="multi-toggle-group mt-2">
          <input name="properties[topSmallNumber]" type="radio" value="no" checked id="top_num_no" data-name="No">
          <label for="top_num_no">No</label>
          <input name="properties[topSmallNumber]" type="radio" value="51712266993966" id="top_num_heat_press" data-name="Heat Press">
          <label for="top_num_heat_press">Heat Press ($6)</label>
          <input name="properties[topSmallNumber]" type="radio" value="51712271188270" id="top_num_embroidery" data-name="Embroidery">
          <label for="top_num_embroidery">Embroidery ($10)</label>
        </div>

        <div class="top_small_number_holder" style="display:none; margin-top:10px;">
          <div class="mb-1">
            <img class="back_number_example" alt="Top Number Example" src="{{ 'top-number.jpg' | asset_url }}" style="width: 160px;">
          </div>
          {% render 'number-fonts', font_holder:'top' %}
        </div>
      </div>
    </div>

    <div id="back_section" class="mt-3">
      <h3 class="mb-0">Back Customizations</h3>
      <h6 class="product-inner-heading">Team name/Last name: ($8.00)</h6>
      <div class="toggle-group">
        <input name="properties[TopLastName]" type="radio" value="no" checked id="top_last_name_no">
        <label for="top_last_name_no">No</label>
        <input name="properties[TopLastName]" type="radio" value="yes" id="top_last_name_yes">
        <label for="top_last_name_yes">Yes</label>
      </div>
      <div class="top_last_name_holder" style="display:none; margin-top:10px;">
        <div style="display: flex; margin-bottom: 10px;">
          <img class="straight_number" alt="Back Name Example" src="{{ 'jacket_last_name.jpg' | asset_url }}" style="width: 160px;">
        </div>
        {% render 'name-fonts', font_holder:'top' %}
      </div>
      
      <div class="player_number_name" style="display: none; margin-top: 20px;"> 
         <div class="row player_number_name" id="top_number_row"></div> 
         <div class="row player_number_name" id="top_name_row" style="margin-top:10px;"></div>
      </div>

    </div>
  </div>
</div>

<script>
  function getTotalQuantity() {
    let total = 0;
    $('.tags-holder .quantity__input').each(function () {
      const value = Number($(this).val());
      if (!isNaN(value)) { total += value; }
    });
    return total;
  }

  function appendNames() {
    // topSmallNumber is active if NOT "no"
    const topSmallNumber = $('input[name="properties[topSmallNumber]"]:checked').val() !== 'no';
    const topLastName = $('input[name="properties[TopLastName]"]:checked').val() === 'yes';
    const total_quantities = getTotalQuantity();
    let prev_quantities = Number("{{ existing_item_min_quantity }}");

    if ((topSmallNumber || topLastName) && (total_quantities > 6 || prev_quantities > 6)) {
      let top_name_content = '';
      let top_number_content = '';
      let i = 0;

      $('.tags-holder .quantity__input').each(function () {
        const value = parseFloat($(this).val());
        const size_tag = $(this).attr('name') || 'item';
        if (!isNaN(value) && value > 0) {
          for (let j = 0; j < value; j++, i++) {
            if (topSmallNumber) {
              top_number_content += `
                <div class="col-4 player_number_input mb-1">
                  <input name="number-${size_tag}-${i+1}" class="input__field player_number" placeholder="Number ${i+1}" type="number" onkeypress="handleOnlyTwoCharacters(event)">
                </div>`;
            }
            if (topLastName) {
              top_name_content += `
                <div class="col-4 player_name_input mb-1">
                  <input name="name-${size_tag}-${i+1}" class="input__field player_name" placeholder="Name ${i+1}" type="text">
                </div>`;
            }
          }
        }
      });
      $('.player_number_name').show();
      $('#top_name_row').html(top_name_content);
      $('#top_number_row').html(top_number_content);
    } else {
      $('.player_number_name').hide().find('#top_name_row, #top_number_row').empty();
    }
  }

  $(document).ready(function() {
    // Crest Logo
    $('input[name="properties[TopCrestLogoType]"]').on('change', function () {
      $(this).val() != 0 ? $('.top_crest_logo_image_holder').slideDown() : $('.top_crest_logo_image_holder').slideUp();
    });

    // Chest Logo
    $('input[name="properties[TopChestLogoType]"]').on('change', function () {
      $(this).val() != 0 ? $('.top_chest_logo_image_holder').slideDown() : $('.top_chest_logo_image_holder').slideUp();
    });

    // Small Number (3-Option)
    $('input[name="properties[topSmallNumber]"]').on('change', function () {
      $(this).val() !== 'no' ? $('.top_small_number_holder').show() : $('.top_small_number_holder').hide();
      appendNames();
    });

    // Back Name (Yes/No)
    $('input[name="properties[TopLastName]"]').on('change', function () {
      $(this).val() === 'yes' ? $('.top_last_name_holder').show() : $('.top_last_name_holder').hide();
      appendNames();
    });

    $(document).on('change', '.quantity__input', appendNames);
    $('#show_custom_info').on('change', function() {
      this.checked ? $('.custom_info').slideDown() : $('.custom_info').slideUp();
    });
  });
</script>