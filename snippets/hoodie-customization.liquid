<div>
  <input
    type="checkbox"
    {% if existing_item_min_quantity == blank or existing_item_min_quantity < 7 %}
      disabled
    {% endif %}
    {% if existing_item_min_quantity > 6 %}
      class="already"
    {% endif %}
    id="show_custom_info"
    name="properties[show_custom_info]"
  >
  <label>Customize this product (Customize and Discounts apply to order quantities of 7+)</label>
  <div class="custom_info" style="display: none; margin-bottom: 10px;">
    <div class="vectorization_info_holder">
      <p>
        <strong>NOTE: </strong>A $25.00 logo processing fee will be applied to cart. Team logos will be on the opposite
        side of the brand logo.
      </p>
    </div>
    <div id="front_section" class="my-1">
      <h3>Front Customizations</h3>
      <div class="crest_logo_holder">
        <h6 class="product-inner-heading">Crest Logo Type:</h6>
        <div class="multi-toggle-group mt-2">
          <input
            checked
            class="imageCheckbox"
            type="radio"
            name="properties[HoodieCrestLogoType]"
            id="hoodie_no_crest_logo"
            value="no"
            data-name="no"
          >
          <label for="hoodie_no_crest_logo">No Logo</label><br>
          <input
            class="imageCheckbox"
            type="radio"
            name="properties[HoodieCrestLogoType]"
            value="50534204342574"
            id="hoodie_crest_heat_press"
            data-name="Heat Press"
          >
          <label for="hoodie_crest_heat_press">Heat Press ($7)</label><br>
          <input
            class="imageCheckbox"
            type="radio"
            name="properties[HoodieCrestLogoType]"
            value="50534209126702"
            id="hoodie_crest_embroidery_press"
            data-name="Embroidery"
          >
          <label for="hoodie_crest_embroidery_press">Embroidery ($12)</label><br>
        </div>
        <div class="hoodie_crest_logo_image_holder logo_holder row" style="display: none; margin-top:10px;margin-left:2px;">
          <div class="col-12 heading">Custom Crest Logo</div>
          <div class="col-7  align-self-center">
            <input
              accept=".png,.svg,.pdf,.ai,.eps,.jpg,.jpeg,.psd,.tif,.tiff"
              onchange="validateFile(this);"
              data-message="Please Choose Crest Logo"
              id="crest_logo"
              name="properties[Crest_Logo]"
              type="file"
            >
          </div>
          <div class="col-5  align-self-center right">
            <img width="" height="" alt="chest-logo.jpge" src="{{ 'crest_logo.png' | asset_url }}">
          </div>
        </div>
      </div>
      <div class="chest_logo_holder">
        <h6 class="product-inner-heading">Chest Logo Type</h6>
        <div class="multi-toggle-group mt-2">
          <input
            checked
            class="imageCheckbox"
            type="radio"
            name="properties[HoodieChestLogoType]"
            id="hoodie_no_chest_logo"
            value="no"
            data-name="no"
          >
          <label for="hoodie_no_chest_logo">No Logo</label><br>
          <input
            class="imageCheckbox"
            type="radio"
            name="properties[HoodieChestLogoType]"
            value="50534216794414"
            id="hoodie_chest_heat_press"
            data-name="Heat Press"
          >
          <label for="hoodie_chest_heat_press">Heat Press ($10)</label><br>
          <input
            class="imageCheckbox"
            type="radio"
            name="properties[HoodieChestLogoType]"
            value="50534221054254"
            id="hoodie_chest_embroidery_press"
            data-name="Embroidery"
          >
          <label for="hoodie_chest_embroidery_press">Embroidery ($15)</label><br>
        </div>
        <div class="hoodie_chest_logo_image_holder logo_holder row" style="display: none;margin-left:2px;">
          <div class="col-12 heading">Custom Chest Logo</div>
          <div class="col-7  align-self-center">
            <input
              accept=".png,.svg,.pdf,.ai,.eps,.jpg,.jpeg,.psd,.tif,.tiff"
              onchange="validateFile(this);"
              data-message="Please Choose Chest Logo"
              id="chest_logo"
              name="properties[Chest_Logo]"
              type="file"
            >
          </div>
          <div class="col-5  align-self-center right">
            <img width="" height="" alt="chest-logo.jpge" src="{{ 'chest-logo.jpg' | asset_url }}">
          </div>
        </div>
      </div>

      <div>
        <h6 class="product-inner-heading">2" Small number:</h6>
        <div class="multi-toggle-group mt-2">
          <input
            name="properties[hoodieSmallNumber]"
            type="radio"
            value="no"
            checked
            id="hoodie_small_no_no"
            data-name="No"
          >
          <label for="hoodie_small_no_no">No</label>

          <input
            name="properties[hoodieSmallNumber]"
            type="radio"
            value="51712280428846"
            id="hoodie_small_heat_press"
            data-name="Heat Press"
          >
          <label for="hoodie_small_heat_press">Heat Press ($6)</label>

          <input
            name="properties[hoodieSmallNumber]"
            type="radio"
            value="51712283312430"
            id="hoodie_small_no_yes"
            data-name="Embroidery"
          >
          <label for="hoodie_small_no_yes">Embroidery ($10)</label>
        </div>
        <div class="hoodie_small_number_holder" style="display:none; margin-top: 10px;">
          <div class="mb-1">
            <div class="back_number">
              <img
                class="back_number_example"
                alt="Back Number Example"
                src="{{ 'hoodie-number.jpg' | asset_url }}"
                style="cursor: pointer; margin-right: 5px; width: 160px;"
              >
            </div>
          </div>
          {% render 'number-fonts', font_holder: 'hoodie' %}
        </div>
      </div>
    </div>

    <div id="back_section">
      <h3 class="mb-0">Back Customizations</h3>
      <div>
        <h6 class="product-inner-heading">Team name/Last name: ($8.00)</h6>
        <div class="toggle-group">
          <input name="properties[HoodieLastName]" type="radio" value="no" checked id="hoodie_last_name_no">
          <label for="hoodie_last_name_no">No</label>
          <input name="properties[HoodieLastName]" type="radio" value="yes" id="hoodie_last_name_yes">
          <label for="hoodie_last_name_yes">Yes</label>
        </div>
        <div class="hoodie_last_name_holder" style="display:none;">
          <div style="display: flex; margin-bottom: 10px;">
            <div class="back_number">
              <img
                class="straight_number"
                alt="Back Number and Straight Name Example"
                src="{{ 'hoodie_last_name.jpg' | asset_url }}"
                style="cursor: pointer; margin-right: 5px; width: 160px;"
              >
            </div>
          </div>
          {% render 'name-fonts', font_holder: 'hoodie' %}
        </div>
      </div>
      <div class="player_number_name" style="display: none; margin-top: 20px; border-top: 1px solid #ddd; padding-top: 10px;">
        <div class="row player_number_name" id="hoodie_number_row"></div>
        <div class="row player_number_name" id="hoodie_name_row" style="margin-top: 10px;"></div>
      </div>
    </div>
  </div>
</div>

<script>
  function getTotalQuantity() {
    let total = 0;
    $('.tags-holder .quantity__input').each(function () {
      const value = Number($(this).val());
      if (!isNaN(value)) {
        total += value;
      }
    });
    return total;
  }

  function appendNameNumbers() {
    const hoodieSmallNumber = $('input[name="properties[hoodieSmallNumber]"]:checked').val() !== 'no';
    const hoodieLastName = $('input[name="properties[HoodieLastName]"]:checked').val() !== 'no';
    console.log(hoodieSmallNumber, hoodieLastName);
    const total_quantities = getTotalQuantity();
    let prev_quantities = Number('{{ existing_item_min_quantity }}');

    if ((hoodieSmallNumber || hoodieLastName) && (total_quantities > 6 || prev_quantities > 6)) {
      let hoodie_number_html = '';
      let hoodie_name_html = '';
      let i = 0;

      $('.tags-holder .quantity__input').each(function () {
        var quantity = parseFloat($(this).val());
        if (quantity > 0 && !isNaN(quantity)) {
          const size_tag = $(this).attr('name') || 'item';
          for (let j = 0; j < quantity; j++, i++) {
            if (hoodieSmallNumber) {
              hoodie_number_html += `
                <div class="col-4 player_number_input mb-1">
                  <input name="number-${size_tag}-${i}" class="input__field player_number" min="0" placeholder="Number ${
                i + 1
              }" onkeypress="handleOnlyTwoCharacters(event)" type="number" value="">
                </div>`;
            }
            if (hoodieLastName) {
              hoodie_name_html += `
                <div class="col-4 player_name_input mb-1">
                  <input name="name-${size_tag}-${i}" class="input__field player_name" placeholder="Name ${
                i + 1
              }" type="text" value="">
                </div>`;
            }
          }
        }
      });
      $('.player_number_name').show();
      $('#hoodie_name_row').html(hoodie_name_html);
      $('#hoodie_number_row').html(hoodie_number_html);
    } else {
      $('.player_number_name').hide().find('#hoodie_number_row, #hoodie_name_row').empty();
    }
  }

  $(document).on('change', 'input[name="properties[hoodieSmallNumber]"]', function () {
    $('.hoodie_small_number_holder').toggle($(this).val() !== 'no');
    appendNameNumbers();
    console.log('change hoodie small number');
  });
  $(document).on('change', 'input[name="properties[HoodieLastName]"]', function () {
    $('.hoodie_last_name_holder').toggle($(this).val() === 'yes');
    appendNameNumbers();
    console.log('change hoodie name');
  });

  $(document).on('change', '.quantity__input', function () {
    appendNameNumbers();
  });

  $('input[name="properties[HoodieCrestLogoType]"]').on('change', function () {
    if ($(this).val() != 0) {
      $('.hoodie_crest_logo_image_holder').slideDown();
    } else {
      $('.hoodie_crest_logo_image_holder').slideUp();
      $('#crest_logo').val('');
    }
  });

  $('input[name="properties[HoodieChestLogoType]"]').on('change', function () {
    if ($(this).val() != 0) {
      $('.hoodie_chest_logo_image_holder').slideDown();
    } else {
      $('.hoodie_chest_logo_image_holder').slideUp();
      $('#chest_logo').val('');
    }
  });

  $('#show_custom_info').on('change', function () {
    this.checked ? $('.custom_info').slideDown() : $('.custom_info').slideUp();
  });
</script>
