{% liquid
  assign theme_rtl = false
  if settings.enable_rtl and settings.langauges_rtl == blank
    assign theme_rtl = true
  endif

  if settings.enable_rtl and settings.langauges_rtl != blank
    assign rtl_languages = settings.langauges_rtl | split: ','
    for language in rtl_languages
      if language == request.locale.iso_code
        assign theme_rtl = true
      endif
    endfor
  endif
%}

{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}
{{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
<style>
    .cart-fee-based-item .cart-item__quantity{
    visibility:hidden;
  }  
</style>
<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>

{%- if theme_rtl -%}
  {{ 'component-cart-items-rtl.css' | asset_url | stylesheet_tag }}
{%- endif -%}
<div class="cart_template_wrapper container section--padding-top">
  <div class="row">
    <div class="col-12">
      <cart-items class="{% if cart == empty %} is-empty{% endif %}">
        <div class="cart__warnings">
          <h1 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h1>
          <a href="{{ section.settings.emply_link | default: routes.all_products_collection_url }}" class="button">
            {{ 'general.continue_shopping' | t }}
          </a>

          {%- if shop.customer_accounts_enabled -%}
            <h2 class="cart__login-title">{{ 'sections.cart.login.title' | t }}</h2>
            <p class="cart__login-paragraph">
              {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
            </p>
          {%- endif -%}
        </div>

        <form action="{{ routes.cart_url }}" class="cart__contents critical-hidden" method="post" id="cart">
          <div class="cart__items" id="main-cart-items" data-id="{{ section.id }}">
            <div class="js-contents">
              {%- if cart != empty -%}
                <table class="cart-items">
                  <thead>
                    <tr>
                      <th class="caption-with-letter-spacing product__title--cart-items" colspan="2" scope="col">
                        {{ 'sections.cart.headings.product' | t }}
                      </th>
                      <th class="medium-hide large-up-hide right caption-with-letter-spacing" colspan="1" scope="col">
                        {{ 'sections.cart.headings.total' | t }}
                      </th>
                      <th
                        class="cart-items__heading--wide small-hide caption-with-letter-spacing"
                        colspan="1"
                        scope="col"
                      >
                        {{ 'sections.cart.headings.quantity' | t }}
                      </th>
                      <th class="small-hide right caption-with-letter-spacing" colspan="1" scope="col">
                        {{ 'sections.cart.headings.total' | t }}
                      </th>
                    </tr>
                  </thead>

                  <tbody>
                    {%- for item in cart.items -%}
                      {% assign is_child_product = false %}
                      {% assign key_type = '' %}
                      {% assign child_property_name = '' %}
                      {% assign fee_tag_found = false %}
                      {% assign customizable_tag_found = false %}
                      {% for tag in item.product.tags %}
                        {% if tag == "fee" %}
                          {%  assign fee_tag_found = true %}
                          {%  assign is_child_product = true %}
                        {% endif %}
                      {% endfor %}
                      {% if item.properties['Item Status'] == 'customized' and fee_tag_found == false %}
                        {% assign customizable_tag_found = true %}
                      {% endif %}

                     
                      {% assign all_property_names = "Count Front Numbers,Count Back Numbers,Count Custom Names,Total Top Numbers,Total Short Numbers,Total Hoodie Numbers,Total Jacket Numbers,Total Pant Numbers,Total Bag Numbers,Total Top Names,Total Hoodie Names,Total Jacket Names,Total Bag Names,Crest Logo Name,Chest Logo Name,total_jacket_heat_press_crest_logos,total_jacket_embroidery_crest_logos,total_pant_heat_press_crest_logos,total_pant_embroidery_crest_logos,total_top_heat_press_crest_logos,total_top_embroidery_crest_logos,total_top_heat_press_chest_logos,total_top_embroidery_chest_logos,total_hoodie_heat_press_crest_logos,total_hoodie_embroidery_crest_logos,total_hoodie_heat_press_chest_logos,total_hoodie_embroidery_chest_logos,total_cap_embroidery_crest_logos" | split: "," %}

                      {% assign concatKeys ="" %}

                      {% for prop in item.properties %}
                        {% assign key = prop[0] %}
                        {% if all_property_names contains key %}
                          {% if concatKeys == "" %}
                            {% assign concatKeys = key %}
                          {% else %}
                            {% assign concatKeys = concatKeys | append: " | " | append: key %}
                          {% endif %}
                        {% endif %}
                      {% endfor %}

                      {% assign title_lower = item.product.title | downcase %}

                      {% if title_lower contains "number" %}
                        {% assign key_type = "number" %}
                      {% elsif title_lower contains "name" %}
                        {% assign key_type = "name" %}
                      {% elsif title_lower contains "logo" %}
                        {% assign key_type = "logo" %} 
                      {% else %}
                        {% assign key_type = "" %}
                      {% endif %}
                    <tr data-item='{{ item.id }}'
                        {% if item.product.tags %}
                          data-status="{{ item.properties['Item Status'] }}"
                        {% endif %}
                        data-id='{{ item.variant_id }}'
                        data-type='{{ item.product.type }}'
                        data-vendor='{{ item.vendor | escape_once | handleize }}'
                        data-customized="{{ customizable_tag_found }}"
                        data-is-variant='{{ is_child_product }}'
                        data-key-type='{{ key_type }}'
                        data-product-id='{{ item.product.id }}'
                        data-additional-properties='{{ concatKeys }}'
                        data-parent-product-id="{% if item.properties['productId'] %}{{ item.properties['productId'] }}{% endif %}"
                        class="cart-item {{ item.properties['Item Status'] }}-item {% if fee_tag_found %} fee cart-fee-based-item{% endif %}{% if customizable_tag_found and fee_tag_found == false %} customized-item{% endif %}"
                        id="CartItem-{{ item.index }}"
                        data-cart-item-key="{{ item.key }}">
                        
                        <td class="cart-item__media">
                          {% comment %} {{ item.properties | json }} {% endcomment %}
                          {% if item.product.tags %}
                            <input type='hidden' class='product_tags' value='{{ item.product.tags }}'>
                          {% endif %}

                          {% comment %} Start hidden fields for numbers {% endcomment %}

                           {% if item.properties['total_jacket_heat_press_crest_logos'] %}
                              <input type="hidden" class="total_jacket_heat_press_crest_logos"
                                    value="{{ item.properties['total_jacket_heat_press_crest_logos'] | default: '' }}">
                           {% endif %}
                           {% if item.properties['total_jacket_embroidery_crest_logos'] %}
                              <input type="hidden" class="total_jacket_embroidery_crest_logos"
                                    value="{{ item.properties['total_jacket_embroidery_crest_logos'] | default: '' }}">
                           {% endif %}

                           {% if item.properties['total_pant_heat_press_crest_logos'] %}
                              <input type="hidden" class="total_pant_heat_press_crest_logos"
                                    value="{{ item.properties['total_pant_heat_press_crest_logos'] | default: '' }}">
                           {% endif %}
                           {% if item.properties['total_pant_embroidery_crest_logos'] %}
                              <input type="hidden" class="total_pant_embroidery_crest_logos"
                                    value="{{ item.properties['total_pant_embroidery_crest_logos'] | default: '' }}">
                           {% endif %}

                           {% if item.properties['total_top_heat_press_crest_logos'] %}
                              <input type="hidden" class="total_top_heat_press_crest_logos"
                                    value="{{ item.properties['total_top_heat_press_crest_logos'] | default: '' }}">
                           {% endif %}
                           {% if item.properties['total_top_embroidery_crest_logos'] %}
                              <input type="hidden" class="total_top_embroidery_crest_logos"
                                    value="{{ item.properties['total_top_embroidery_crest_logos'] | default: '' }}">
                           {% endif %}
                           {% if item.properties['total_top_heat_press_chest_logos'] %}
                              <input type="hidden" class="total_top_heat_press_chest_logos"
                                    value="{{ item.properties['total_top_heat_press_chest_logos'] | default: '' }}">
                           {% endif %}
                           {% if item.properties['total_top_embroidery_chest_logos'] %}
                              <input type="hidden" class="total_top_embroidery_chest_logos"
                                    value="{{ item.properties['total_top_embroidery_chest_logos'] | default: '' }}">
                           {% endif %}

                           {% if item.properties['total_hoodie_heat_press_crest_logos'] %}
                              <input type="hidden" class="total_hoodie_heat_press_crest_logos"
                                    value="{{ item.properties['total_hoodie_heat_press_crest_logos'] | default: '' }}">
                           {% endif %}
                           {% if item.properties['total_hoodie_embroidery_crest_logos'] %}
                              <input type="hidden" class="total_hoodie_embroidery_crest_logos"
                                    value="{{ item.properties['total_hoodie_embroidery_crest_logos'] | default: '' }}">
                           {% endif %}
                           {% if item.properties['total_hoodie_heat_press_chest_logos'] %}
                              <input type="hidden" class="total_hoodie_heat_press_chest_logos"
                                    value="{{ item.properties['total_hoodie_heat_press_chest_logos'] | default: '' }}">
                           {% endif %}
                           {% if item.properties['total_hoodie_embroidery_chest_logos'] %}
                              <input type="hidden" class="total_hoodie_embroidery_chest_logos"
                                    value="{{ item.properties['total_hoodie_embroidery_chest_logos'] | default: '' }}">
                           {% endif %}

                           {% if item.properties['total_cap_embroidery_crest_logos'] %}
                              <input type="hidden" class="total_cap_embroidery_crest_logos"
                                    value="{{ item.properties['total_cap_embroidery_crest_logos'] | default: '' }}">
                           {% endif %}



                           {% if item.properties['Short Number'] %}
                              <input type="hidden" class="short_number_variant_id"
                                    value="{{ item.properties['Short Number Variant Id'] | default: '' }}">
                            {% endif %}

                            {% if item.properties['Top Small Number'] %}
                              <input type="hidden" class="top_small_number_variant_id"
                                    value="{{ item.properties['Top Small Number Variant Id'] | default: '' }}">
                            {% endif %}

                            {% if item.properties['Hoodie Small Number'] %}
                              <input type="hidden" class="hoodie_small_number_variant_id"
                                    value="{{ item.properties['Hoodie Small Number Variant Id'] | default: '' }}">
                            {% endif %}

                            {% if item.properties['Jacket Small Number'] %}
                              <input type="hidden" class="jacket_small_number_variant_id"
                                    value="{{ item.properties['Jacket Small Number Variant Id'] | default: '' }}">
                            {% endif %}

                            {% if item.properties['Pant Small Number'] %}
                              <input type="hidden" class="pant_small_number_variant_id"
                                    value="{{ item.properties['Pant Small Number Variant Id'] | default: '' }}">
                            {% endif %}

                            {% if item.properties['Bag Small Number'] %}
                              <input type="hidden" class="bag_small_number_variant_id"
                                    value="{{ item.properties['Bag Small Number Variant Id'] | default: '' }}">
                            {% endif %}

                            {% comment %} End hidden fields for numbers {% endcomment %}
                                
                          {% if item.properties['Crest Logo Name'] %}
                            {%  assign  child_product_type ='logo_name' %}
                            <input type='hidden' class='crest_logo_name' value='{{ item.properties['Crest Logo Name'] }}'>
                          {% endif %}

                          {% if item.properties['Crest Logo Variant Id'] %}
                            <input type='hidden' class='crest_logo_variant_id' value='{{ item.properties['Crest Logo Variant Id'] }}'>
                          {% endif %}
                                
                          {% if item.properties['Chest Logo Name'] %}
                              {%  assign  child_product_type ='logo_name' %}
                              <input type='hidden' class='chest_logo_name' value='{{ item.properties['Chest Logo Name'] }}'>
                          {% endif %}
                                
                          {% if item.product.type %}
                              <input type='hidden' class='product_type' value='{{ item.product.type }}'>
                          {% endif %}
                                
                          {% if item.vendor %}
                            <input type='hidden' class='vendor' value='{{ item.vendor | escape_once | handleize }}'>
                          {% endif %}
                                
                          {% if item.properties['Front Number'] %}
                            {%  assign  child_product_type ='number' %}
                            <input type='hidden' class='alreadyFrontNumber' value='{{ item.properties['Front Number'] }}'>
                          {% endif %}
                                
                          {% if item.properties['Back Number'] %}
                            {%  assign  child_product_type ='number' %}
                            <input type='hidden' class='alreadyBackNumber' value='{{ item.properties['Back Number'] }}'>
                          {% endif %}
                                
                          {% if item.properties['Last Name'] %}
                            {%  assign  child_product_type ='name' %}
                            <input type='hidden' class='alreadyCustomName' value='{{ item.properties['Last Name'] }}'>
                          {% endif %}
                                
                          {% if item.properties['Count Front Numbers'] %}
                            {%  assign  child_product_type ='number' %}
                            <input type='hidden' class='totalFrontNumbers' value='{{ item.properties['Count Front Numbers'] }}'>
                          {% endif %}
                                
                          {% if item.properties['Count Back Numbers'] %}
                            {%  assign  child_product_type ='number' %}
                            <input type='hidden' class='totalBackNumbers' value='{{ item.properties['Count Back Numbers'] }}'>
                          {% endif %}
                                
                          {% if item.properties['Count Custom Names'] %}
                            {%  assign  child_product_type ='name' %}
                            <input type='hidden' class='totalNames' value='{{ item.properties['Count Custom Names'] }}'>
                          {% endif %}

                          {% if item.properties['Bag Logo Type'] %}
                              <input type='hidden' class='bagLogoType' value='{{ item.properties['Bag Logo Type'] }}'>
                          {% endif %}

                          {% if item.properties['Bag Logo Id'] %}
                              <input type='hidden' class='bagLogoId' value='{{ item.properties['Bag Logo Id'] }}'>
                          {% endif %}

                          {% if item.properties['Pant Logo Type'] %}
                              <input type='hidden' class='pantLogoType' value='{{ item.properties['Pant Logo Type'] }}'>
                          {% endif %}

                          {% if item.properties['Jacket Logo Type'] %}
                              <input type='hidden' class='jacketLogoType' value='{{ item.properties['Jacket Logo Type'] }}'>
                          {% endif %}
                          
                          {% if item.properties['Top Crest Logo Type'] %}
                              <input type='hidden' class='topCrestLogoType' value='{{ item.properties['Top Crest Logo Type'] }}'>
                          {% endif %}
                          {% if item.properties['Top Chest Logo Type'] %}
                              <input type='hidden' class='topChestLogoType' value='{{ item.properties['Top Chest Logo Type'] }}'>
                          {% endif %}

                          {% if item.properties['Hoodie Crest Logo Type'] %}
                              <input type='hidden' class='hoodieCrestLogoType' value='{{ item.properties['Hoodie Crest Logo Type'] }}'>
                          {% endif %}

                          {% if item.properties['Hoodie Chest Logo Type'] %}
                              <input type='hidden' class='hoodieChestLogoType' value='{{ item.properties['Hoodie Chest Logo Type'] }}'>
                          {% endif %}

                          {% if item.properties['Cap Crest Logo Type'] %}
                              <input type='hidden' class='capCrestLogoType' value='{{ item.properties['Cap Crest Logo Type'] }}'>
                          {% endif %}

                          {% if item.properties['Sleeve Logo'] %}
                              <input type='hidden' class='jerseySleeveLogoEnabled' value='{{ item.properties['Sleeve Logo'] }}'>
                              <input type='hidden' class='jerseySleeveLogoName' value='{{ item.properties['Sleeve Logo Name'] | default: '' }}'>
                              <input type='hidden' class='jerseySleeveLogoType' value='{{ item.properties['Sleeve Logo Type'] | default: '' }}'>
                          {% endif %}

                          {% if item.properties['Sponsor/Team Logo'] %}
                              <input type='hidden' class='jerseySponsorLogoEnabled' value='{{ item.properties['Sponsor/Team Logo'] }}'>
                              <input type='hidden' class='jerseySponsorLogoName' value='{{ item.properties['Sponsor Logo Name'] | default: '' }}'>
                          {% endif %}

                        
                          {% if item.properties['Total Pant Numbers'] %}
                            {%  assign  child_product_type ='number' %}
                            <input type='hidden' class='totalPantNumbers' value='{{ item.properties['Total Pant Numbers'] }}'>
                          {% endif %} 

                          {% if item.properties['Total Jacket Numbers'] %}
                              {%  assign  child_product_type ='number' %}
                              <input type='hidden' class='totalJacketNumbers' value='{{ item.properties['Total Jacket Numbers'] }}'>
                          {% endif %}

                          {% if item.properties['Total Jacket Names'] %}
                              {%  assign  child_product_type ='name' %}
                              <input type='hidden' class='totalJacketNames' value='{{ item.properties['Total Jacket Names'] }}'>
                          {% endif %}

                          {% if item.properties['Total Short Numbers'] %}
                            {%  assign  child_product_type ='number' %}
                            <input type='hidden' class='totalShortNumbers' value='{{ item.properties['Total Short Numbers'] }}'>
                          {% endif %}

                          {% if item.properties['Total Top Numbers'] %}
                            {%  assign  child_product_type ='number' %}
                            <input type='hidden' class='totalTopNumbers' value='{{ item.properties['Total Top Numbers'] }}'>
                          {% endif %}

                      
                          {% if item.properties['Total Top Names'] %}
                            {%  assign  child_product_type ='name' %}
                            <input type='hidden' class='totalTopNames' value='{{ item.properties['Total Top Names'] }}'>
                          {% endif %}

                          {% if item.properties['Total Hoodie Numbers'] %}
                            {%  assign  child_product_type ='number' %}
                            <input type='hidden' class='totalHoodieNumbers' value='{{ item.properties['Total Hoodie Numbers'] }}'>
                          {% endif %}

                          {% if item.properties['Total Hoodie Names'] %}
                            {%  assign  child_product_type ='name' %}
                            <input type='hidden' class='totalHoodieNames' value='{{ item.properties['Total Hoodie Names'] }}'>
                          {% endif %}

                          {% if item.properties['Total Bag Numbers'] %}
                            {%  assign  child_product_type ='number' %}
                            <input type='hidden' class='totalBagNumbers' value='{{ item.properties['Total Bag Numbers'] }}'>
                          {% endif %}

                          {% if item.properties['Total Bag Names'] %}
                            {%  assign  child_product_type ='name' %}
                            <input type='hidden' class='totalBagNames' value='{{ item.properties['Total Bag Names'] }}'>
                            <input type="hidden" class="bag_name_variant_id" value="{{ item.properties['Bag Name Variant Id'] | default: '' }}">
                          {% endif %}
                          
                          {% if item.properties['Custom Info'] %}
                              {% assign entries = item.properties['Custom Info'] | split: "),(" %}
                              {% assign numbers = "" %}
                              {% assign names = "" %}

                              {% for entry in entries %}
                                {% assign clean_entry = entry | remove: "(" | remove: ")" %}
                                {% assign parts = clean_entry | split: ", " %}
                                {% assign numbers = numbers | append: parts[0] | append: "," %}
                                {% assign names = names | append: parts[1] | append: "," %}
                              {% endfor %}

                              {%- assign numbers = numbers | slice: 0, numbers.size | rstrip: "," -%}
                              {%- assign names = names | slice: 0, names.size | rstrip: "," -%}

                              <input class='numbers' type="hidden" name="numbers" value="{{ numbers }}">
                              <input class='names' type="hidden" name="names" value="{{ names }}">

                          {% endif %}

                          {% if item.image %}
                            <a href="{{ item.url }}">
                              <img
                                class="cart-item__image"
                                src="{{ item.image | img_url: '150x' }}"
                                alt="{{ item.image.alt | escape }}"
                                loading="lazy"
                                width="100"
                                height="{{ 100 | divided_by: item.image.aspect_ratio | ceil }}"
                              >
                            </a>
                          {% endif %}
                        </td>

                        <td class="cart-item__details">
                          {%- if section.settings.show_vendor -%}
                            <p class="light">{{ item.product.vendor }}</p>
                          {%- endif -%}

                          <a href="{{ item.url }}" class="cart-item__name break">{{ item.product.title | escape }}</a>

                          {%- if item.product.has_only_default_variant == false
                            or item.properties.size != 0
                            or item.selling_plan_allocation != null
                          -%}
                            <dl>
                              {%- if item.product.has_only_default_variant == false -%}
                                {%- for option in item.options_with_values -%}
                                  <div class="product-option">
                                    <dt>{{ option.name }}:</dt>
                                    <dd>{{ option.value }}</dd>
                                  </div>
                                {%- endfor -%}
                              {%- endif -%}                              
 
                              {%- for property in item.properties -%}
                                {%- assign property_first_char = property.first | slice: 0 -%}
                                {%- if property.last != blank and property_first_char != '_' -%}
                                
                                  <div class="product-option others" style="display:none">
                                    <dt>{{ property.first }}:</dt>
                                    <dd>
                                      {%- if property.last contains '/uploads/' -%}
                                        <a href="{{ property.last }}" target="_blank">
                                          {{ property.last | split: '/' | last }}
                                        </a>
                                      {%- else -%}
                                        {{ property.last | capitalize }}
                                      {%- endif -%}
                                    </dd>
                                  </div>
                                {%- endif -%}
                              {%- endfor -%}                              
                            </dl>
                            <!-- Start Price -->
                            {% if customizable_tag_found %}
                              <p class="cart-item__old-price price ">{{ item.product.price | money }}</p>
                            {% else %}
                               <p class="cart-item__old-price price ">{{ item.product.price | money }}</p>
                            {% endif %}
                            <!-- End Price  -->
                            <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                          {%- endif -%}
                                
                          <ul
                            class="discounts list-unstyled"
                            role="list"
                            aria-label="{{ 'customer.order.discount' | t }}"
                          >
                            {%- for discount in item.discounts -%}
                              <li class="discounts__discount">
                                {%- render 'icon-discount' -%}
                                {{ discount.title }}
                              </li>
                            {%- endfor -%}
                          </ul>

                          <p class="cart-item__error" id="Line-item-error-{{ item.index }}" data-cart-item-key="{{ item.key }}">
                            <span class="cart-item__error-text"></span>
                            <svg
                              aria-hidden="true"
                              focusable="false"
                              role="presentation"
                              class="icon icon-error"
                              viewBox="0 0 13 13"
                            >
                              <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
                              <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
                              <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
                              <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
                            </svg>
                          </p>
                          {% if fee_tag_found==false and customizable_tag_found %}
                            <div class="showDetailProperties button button--small show" 
                                  style="margin-top: 15px; background-color: white; color: black; border-color: black;">
                              Show Details
                            </div>
                          {% endif %}
                        </td>

                        <td class="cart-item__totals right medium-hide large-up-hide">
                          <div class="loading-overlay hidden">
                            <div class="loading-overlay__spinner">
                              <svg
                                aria-hidden="true"
                                focusable="false"
                                role="presentation"
                                class="spinner"
                                viewBox="0 0 66 66"
                                xmlns="http://www.w3.org/2000/svg"
                              >
                                <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                              </svg>
                            </div>
                          </div>
                          <div class="cart-item__price-wrapper">
                            {%- if item.original_line_price != item.final_line_price -%}
                              <dl class="cart-item__discounted-prices">
                                <dt class="visually-hidden">
                                  {{ 'products.product.price.regular_price' | t }}
                                </dt>
                                <dd>
                                  <s class="cart-item__old-price price price--end">
                                    {{ item.original_line_price | money }}
                                  </s>
                                </dd>
                                <dt class="visually-hidden">
                                  {{ 'products.product.price.sale_price' | t }}
                                </dt>
                                <dd class="price price--end">
                                  {{ item.final_line_price | money }}
                                </dd>
                              </dl>
                            {%- else -%}
                              <span class="price price--end">
                                {{ item.original_line_price | money }}
                              </span>
                            {%- endif -%}

                            {%- if item.variant.available and item.unit_price_measurement -%}
                              <div class="unit-price caption">
                                <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
                                {{ item.variant.unit_price | money }}
                                <span aria-hidden="true">/</span>
                                <span class="visually-hidden"
                                  >&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span
                                >
                                {%- if item.variant.unit_price_measurement.reference_value != 1 -%}
                                  {{- item.variant.unit_price_measurement.reference_value -}}
                                {%- endif -%}
                                {{ item.variant.unit_price_measurement.reference_unit }}
                              </div>
                            {%- endif -%}
                          </div>
                        </td>

                        <td class="cart-item__quantity">
                          <label class="visually-hidden" for="Quantity-{{ item.index }}" data-cart-item-key="{{ item.key }}">
                            {{ 'products.product.quantity.label' | t }}
                          </label>
                          {% if customizable_tag_found and fee_tag_found == false %}
                            <div class="quantity">
                          {% else %}
                            <quantity-input class="quantity">
                          {% endif %}
                            <button class="quantity__button no-js-hidden" name="minus" type="button" data-product-id="{{ item.product.id }}" data-id="{{ item.id }}" data-key="{{ item.key }}">
                              <span class="visually-hidden">
                                {{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}
                              </span>
                              {% render 'icon-minus' %}
                            </button>
                            <input
                              class="quantity__input"
                              type="number"
                              name="updates[]"
                              value="{{ item.quantity }}"
                              min="0"
                              data-id="{{ item.id }}"
                              readonly
                              aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                              id="Quantity-{{ item.index }}"
                              data-cart-item-key="{{ item.key }}"
                              data-index="{{ item.index }}"
                            >
                            <button class="quantity__button no-js-hidden" name="plus" type="button" data-product-id="{{ item.product.id }}" data-id="{{ item.id }}" data-key="{{ item.key }}">
                              <span class="visually-hidden">
                                {{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}
                              </span>
                              {% render 'icon-plus' %}
                            </button>
                          {% if customizable_tag_found and fee_tag_found == false %}
                            </div>
                          {% else %}
                            </quantity-input>
                          {% endif %}
                          <a class="button button--tertiary cart-remove-button"
                              data-product-id="{{ item.product.id }}"
                              data-customized="{{ customizable_tag_found }}"
                              data-id="{{ item.id }}"
                              data-key="{{ item.key }}"
                              data-index="{{ item.index }}"
                              aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}">
                               <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="#b0b0b0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                  <polyline points="2 4 14 4" />
                                  <path d="M13 4L12.4 13.4C12.3 14.3 11.5 15 10.6 15H5.4C4.5 15 3.7 14.3 3.6 13.4L3 4M6 7V12M10 7V12M5 4V2C5 1.5 5.5 1 6 1H10C10.5 1 11 1.5 11 2V4" />
                               </svg>
                          </a>
                        </td>

                        <td class="cart-item__totals right small-hide">
                          <div class="loading-overlay hidden">
                            <div class="loading-overlay__spinner">
                              <svg
                                aria-hidden="true"
                                focusable="false"
                                role="presentation"
                                class="spinner"
                                viewBox="0 0 66 66"
                                xmlns="http://www.w3.org/2000/svg"
                              >
                                <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                              </svg>
                            </div>
                          </div>

                          <div class="cart-item__price-wrapper">
                            {%- if item.original_line_price != item.final_line_price -%}
                              <dl class="cart-item__discounted-prices">
                                <dt class="visually-hidden">
                                  {{ 'products.product.price.regular_price' | t }}
                                </dt>
                                <dd>
                                  <s class="cart-item__old-price price price--end">
                                    {{ item.original_line_price | money }}
                                  </s>
                                </dd>
                                <dt class="visually-hidden">
                                  {{ 'products.product.price.sale_price' | t }}
                                </dt>
                                <dd class="price price--end">
                                  {{ item.final_line_price | money }}
                                </dd>
                              </dl>
                            {%- else -%}
                              <span class="price price--end">
                                {{ item.original_line_price | money }}
                              </span>
                            {%- endif -%}

                            {%- if item.variant.available and item.unit_price_measurement -%}
                              <div class="unit-price caption">
                                <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
                                {{ item.variant.unit_price | money }}
                                <span aria-hidden="true">/</span>
                                <span class="visually-hidden"
                                  >&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span
                                >
                                {%- if item.variant.unit_price_measurement.reference_value != 1 -%}
                                  {{- item.variant.unit_price_measurement.reference_value -}}
                                {%- endif -%}
                                {{ item.variant.unit_price_measurement.reference_unit }}
                              </div>
                            {%- endif -%}
                          </div>
                        </td>
                      </tr>
                    {%- endfor -%}
                  </tbody>
                </table>
              {%- endif -%}
            </div>
          </div>

          <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
          <p
            class="visually-hidden"
            id="shopping-cart-line-item-status"
            aria-live="polite"
            aria-hidden="true"
            role="status"
          >
            {{ 'accessibility.loading' | t }}
          </p>
        </form>
      </cart-items>
    </div>
  </div>
</div>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script>
  $(document).ready(function() {

    $(".cart-fee-based-item .cart-item__quantity").css('visibility','hidden');
    $('.showDetailProperties').on('click', function(){      
      if($(this).hasClass('show')){        
        //$(this).siblings('.others').show();
        $(this).parent().find('.others').show();
        $(this).removeClass('show');
        $(this).addClass('hide');
        $(this).text('Hide Details');
      }
      else if($(this).hasClass('hide')){
        //$(this).siblings('.others').hide();
        $(this).parent().find('.others').hide();
        $(this).removeClass('hide');
        $(this).addClass('show');
        $(this).text('Show Details');
      }
    });
  });    
</script>  

{% schema %}
{
  "name": "t:sections.main-cart-items.name",
  "settings": [
       {
        "type": "checkbox",
        "id": "show_vendor",
        "default": false,
         "label": "t:sections.main-cart-items.settings.show_vendor.label"
      },
      {
        "type": "header",
        "content": "Button"
      },
      {
       "type": "url",
       "id": "emply_link",
        "info": "When cart is empty, a button will appear to contune shopping",
       "label": "t:sections.slideshow.blocks.slide.settings.link.label"
     }
  ]
}
{% endschema %}
