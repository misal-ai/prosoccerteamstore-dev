                          {% for item in youth_size_tags %}
                            {% if item == tag %}                            
                              {% assign tag_existed = true %}                                       
                            {% endif %}  
                          {% endfor %}  
                          {% if tag_existed == false %}
                            {% assign temp_size_tags = temp_size_tags | append: ", " | append: tag %}
                            {% assign youth_size_tags = temp_size_tags | split: ", " %}
                          {% endif %}  
                        {% else %}
                          {% assign temp_size_tags = temp_size_tags | append: tag %}                                                                                  
                          {% assign youth_size_tags = temp_size_tags | split: ", " %}
                        {% endif %}                                                                      
                      {% endif %}                                        
                    {% endfor %}                                                                                         
                  {% endfor %}
                  
                  {% for tag in temp_product_tags %}                                    
                    {% if tag contains 'Youth_' or scrimmage_vest_youth_tags contains tag %}
                      {% if youth_size_tags.size != 0 %}  
                          {% assign tag_existed = false %}                                       
                          {% for item in youth_size_tags %}
                            {% if item == tag %}                            
                              {% assign tag_existed = true %}                                       
                            {% endif %}  
                          {% endfor %}  
                          {% if tag_existed == false %}
                            {% assign temp_size_tags = temp_size_tags | append: ", " | append: tag %}
                            {% assign youth_size_tags = temp_size_tags | split: ", " %}
                          {% endif %}  
                        {% else %}
                          {% assign temp_size_tags = temp_size_tags | append: tag %}                                                                                  
                          {% assign youth_size_tags = temp_size_tags | split: ", " %}
                        {% endif %}                                         
                    {% endif %}
                  {% endfor %}
                  <div class="youth" class="mt-1">
                    <h3>Youth Sizes</h3>
                    <div class="tags-holder row">                    
                      {% for tag in youth_size_tags %}      
                          {% assign tag_name = tag | remove: 'Youth_' %}
                        <div class=" size_line y{{ tag_name | downcase }} col-4">                    
                          <div class="product-form__input product-form__quantity">
                            <label class="form__label" for="Quantity-{{ section.id }}">
                            
                              <strong>{{ tag_name }}</strong>
                            </label>            
                            <quantity-input class="quantity {{ tag_name }}">
                              <button class="quantity__button no-js-hidden" name="minus" type="button">
                                <span class="visually-hidden">
                                  {{- 'products.product.quantity.decrease' | t: product: product.title | escape -}}
                                </span>
                                {% render 'icon-minus' %}
                              </button>
                              <input
                                class="quantity__input"
                                type="number"
                                name="{{ tag }}"
                                id="Quantity-{{ tag_name }}-{{ section.id }}"
                                min="0"
                                value="0"
                                form="product-form-{{ section.id }}"
                                size_tag="{{ tag_name }}"
                                data-variant-id="{{ current_variant.id }}"
                              >
                              <button class="quantity__button no-js-hidden" name="plus" type="button">
                                <span class="visually-hidden">
                                  {{- 'products.product.quantity.increase' | t: product: product.title | escape -}}
                                </span>
                                {% render 'icon-plus' %}
                              </button>
                            </quantity-input>
                          </div>
                        </div>
                      {% endfor %}
                    </div>  
                  </div>
                {% endif %}            
              </div>  
            {% endif %}
