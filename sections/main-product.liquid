                      function updateButtonState(){
                          var inputs = $('.product-form__quantity .quantity__input');
                          var sum = inputs.toArray().reduce((acc, el) => acc + (Number(el.value) || 0), 0);
                          var isCustomized = $('#show_custom_info').is(':checked');

                          if (isVest && isCustomized) {
                              var allValid = inputs.toArray().every(el => {
                                  var val = Number(el.value) || 0;
                                  return val === 0 || val % 12 === 0;
                              });
                              checkout_btn.prop('disabled', !allValid);
                          }
                          else if (socks === "true" && product_vendor === "Joma") {
                              // Joma socks must always be multiples of 4, customized or not
                              checkout_btn.prop('disabled', sum === 0 || sum % 4 !== 0);
                          }
                          else if (isCustomized) {
                              checkout_btn.prop('disabled', sum < minOrder);
                          }
                          else {
                              checkout_btn.prop('disabled', sum < 1);
                          }

                          // 🔴 Prevent override for vest
                          if (!isVest && $('#show_custom_info').hasClass('already') && product_vendor !== "Joma") {
                              checkout_btn.removeAttr('disabled');
                          }
                      }
                  
                      $(document).on('change','.product-form__quantity .quantity__input',updateButtonState);
                      $('select[name="options[Color]"]').on('change',function(){
                          showLoader();
                          setTimeout(function(){
                              updateButtonState();
                              hideLoader();
                          },2000);
                      });
                  });
                </script>   
