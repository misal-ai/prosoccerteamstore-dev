                  function addToCart(variantId, properties, quantity, callback) {
                    // Construct the data object with variant ID, properties, and quantity
                    var data = {
                      id: variantId,
                      properties: properties,
                      quantity: quantity
                    };
                  
                    $.ajax({
                      url: '/cart/add.js',
